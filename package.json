{
  "name": "aml-guardian-pro",
  "version": "1.0.0",
  "description": "UK Accountancy AML Compliance Software with AI-powered risk assessment",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:studio": "cd backend && npx prisma studio",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "deploy": "./scripts/deploy-railway.sh",
    "deploy:backend": "./scripts/deploy-railway.sh backend",
    "deploy:frontend": "./scripts/deploy-railway.sh frontend",
    "railway:login": "railway login"
  },
  "keywords": [
    "aml",
    "compliance",
    "accountancy",
    "uk",
    "anti-money-laundering",
    "risk-assessment",
    "companies-house"
  ],
  "author": "AML Guardian Pro",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
