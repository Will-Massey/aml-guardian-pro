# Production Environment Variables for Railway + Neon
# Copy this file and fill in your actual values

# Neon PostgreSQL Connection String
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://[user]:[password]@[neon-host]/[database]?sslmode=require"

# JWT Configuration
# Generate a secure random string (min 32 characters)
JWT_SECRET="your-super-secure-production-secret-min-32-chars"
JWT_EXPIRES_IN="24h"
BCRYPT_ROUNDS="12"

# Companies House API
# Get your API key from: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key"
COMPANIES_HOUSE_BASE_URL="https://api.company-information.service.gov.uk"

# AI Configuration (via Kimi/Claurst)
CLAURST_PROVIDER="anthropic"
CLAURST_MODEL="claude-opus-4"

# Server Configuration
PORT="3000"
NODE_ENV="production"
FRONTEND_URL="https://your-frontend-url.up.railway.app"

# Security
# Update this with your actual frontend URL after deployment
CORS_ORIGINS="https://your-frontend-url.up.railway.app"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# File Storage (Railway uses ephemeral storage)
UPLOAD_DIR="/tmp/uploads"
MAX_FILE_SIZE="10485760"

# Logging
LOG_LEVEL="info"
